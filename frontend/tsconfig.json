{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "lucide-vue-next": ["node_modules/lucide-vue-next"],
      "vue": ["node_modules/vue"],
      "xlsx": ["node_modules/xlsx"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue", "../extensions/*/src/**/*.ts", "../extensions/*/src/**/*.vue"],
  "references": []
}
